doctype html
html(lang="en" class="h-100")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no")
    meta(name="description" content="")
    link(rel="shortcut icon" href="../favicon.ico")
    title Examen de Medio Semestre - Desarrollo web 3

    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet")
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js")

    style.
      .bd-placeholder-img {
        font-size: 1.125rem;
        text-anchor: middle;
        -webkit-user-select: none;
        -moz-user-select: none;
        user-select: none;
      }

      input[readonly] {
        background-color: #f4ebeb;
        color: #555;
        border: 1px solid #ccc;
        cursor: not-allowed;
      }

      @media (min-width: 768px) {
        .bd-placeholder-img-lg {
          font-size: 3.5rem;
        }
      }

    link(href="../stylesheets/cover.css" rel="stylesheet")

  body.d-flex.h-100.text-center.text-white.bg-dark
    .cover-container.d-flex.w-100.h-100.p-3.mx-auto.flex-column
      header.mb-auto
        div
          h3.float-md-start.mb-0 Examen No. 1
          nav.nav.nav-masthead.justify-content-center.float-md-end
            a.nav-link(href="/") Inicio
            a.nav-link.active(aria-current="page" href="/addUser") Añadir Usuarios
            a.nav-link(href="/changeUser") Modificar Usuarios

      main.inner.cover.bg-dark(role="main")
        hr(style="background-color: white;")
        h1.text-center Creación de usuarios

        .row
          .col-md-12
            .card
              .card-body.bg-secondary
                form(action="/users/create" method="post" role="form").row.g-3
                  .col-md-6
                    label.form-label(for="inputNombreAdd") Nombre
                    input#inputNombreAdd.form-control(type="text" name="nombre" placeholder="Ingrese el nombre del usuario")

                  .col-md-6
                    label.form-label(for="inputApellidoAdd") Apellido
                    input#inputApellidoAdd.form-control(type="text" name="apellido" placeholder="Ingrese el apellido del usuario")

                  .col-md-6
                    label.form-label(for="inputDireccionAdd") Dirección
                    input#inputDireccionAdd.form-control(type="text" name="direccion" placeholder="Ingrese la dirección del usuario")

                  .col-md-6
                    label.form-label(for="inputEmailAdd") email
                    input#inputEmailAdd.form-control(type="text" name="email" placeholder="Ingrese el email del usuario" readonly)

                  .col-md-4
                    label.form-label(for="inputIdentificacionAdd") Identificación
                    input#inputIdentificacionAdd.form-control(type="number" name="identificacion" placeholder="Ingrese la identificación del usuario")

                  .col-md-4
                    label.form-label(for="inputEdadAdd") Edad
                    input#inputEdadAdd.form-control(type="number" name="edad" placeholder="Ingrese la edad del usuario")

                  .col-md-4
                    label.form-label(for="inputTelefonoAdd") Teléfono
                    input#inputTelefonoAdd.form-control(type="number" name="telefono" placeholder="Ingrese el teléfono del usuario")

                  .col-md-6
                    .col-md-12.mb-3
                      label.form-label(for="selectTipoAdd") Tipo de Materia
                      select#selectTipoAdd.form-select(name="tipo")
                        option(selected) Seleccione el tipo de materia
                        option(value="Presencial") Presencial
                        option(value="Virtual") Virtual

                    .col-md-12.mb-3
                      label.form-label(for="inputCarreraAdd") Carrera
                      input#inputCarreraAdd.form-control(type="text" name="carrera" placeholder="Ingrese el nombre de la carrera" readonly)

                    .col-md-12.mb-3
                      label.form-label(for="inputFechaAdd") Fecha de Creación
                      input#inputFechaAdd.form-control(type="date" name="creado" placeholder="Fecha Actual")

                  .col-md-6.d-flex.mb-3
                    label.col-md-3.col-form-label(for="selectMateriasAdd") Materias
                    select#selectMateriasAdd.form-select(name="nombres" multiple aria-label="multiple select materias")
                      option(selected) Seleccione las materias
                      option(value="Desarrollo web 1") Desarrollo web 1
                      option(value="Desarrollo web 2") Desarrollo web 2
                      option(value="Desarrollo web 3") Desarrollo web 3
                      option(value="Fotografía 1") Fotografía 1
                      option(value="Fotografía 2") Fotografía 2
                      option(value="Fotografía 3") Fotografía 3
                      option(value="Periodismo 1") Periodismo 1
                      option(value="Periodismo 2") Periodismo 2
                      option(value="Periodismo 3") Periodismo 3

                  button.btn.btn-dark.btn-outline-secondary(type="submit") Crear Usuario

        hr(style="background-color: white;")

      footer.mt-auto.text-white-50
        p
          | Desarrollo web 3 
          a.text-danger(href="https://www.usfq.edu.ec/es" target="_blank") USFQ
          | , Examen de medio semestre.